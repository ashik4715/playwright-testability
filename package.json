{
  "name": "playwright-conduit-tests",
  "version": "1.0.0",
  "description": "Comprehensive Playwright E2E testing framework for Conduit application",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:parallel": "playwright test --workers=4",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "report:allure": "allure generate allure-results --clean && allure open",
    "report:html": "playwright show-report",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "typescript",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "allure-playwright": "^3.0.4",
    "eslint": "^8.57.0",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1"
  }
}
